</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>FBTparams</parametername>
</parameternamelist>
<parameterdescription>
<para>pointer to a struct containing nu, Q and function to integrate </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
